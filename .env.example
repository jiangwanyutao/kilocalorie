# =============================================================================
# 千卡日记 · 环境变量模板
# 复制为 .env（勿提交），或复制到 api/.env 和 web/.env
# 所有 REPLACE_WITH_* 是占位符，需替换成真实值
# =============================================================================

# --- App ---
APP_NAME=千卡日记
APP_ENV=development
APP_PORT_API=7100
APP_PORT_WEB=7110

# --- Database (复用宿主 PostgreSQL) ---
DB_HOST=YOUR_INTERNAL_IP
DB_PORT=5432
DB_ADMIN_USER=postgres
DB_ADMIN_PWD=REPLACE_WITH_REAL_PWD
DB_NAME=qianka
DB_USER=qk
DB_PWD=REPLACE_WITH_STRONG_PWD

# 完整 URL（NestJS TypeORM 会用）
DATABASE_URL=postgres://qk:REPLACE_WITH_STRONG_PWD@YOUR_INTERNAL_IP:5432/qianka

# --- Redis (复用宿主 Redis, 用 DB 5 隔离千卡日记) ---
REDIS_URL=redis://YOUR_INTERNAL_IP:6379/5

# --- MinIO (复用宿主 MinIO) ---
MINIO_ENDPOINT=YOUR_INTERNAL_IP
MINIO_PORT=9000
MINIO_ACCESS_KEY=REPLACE_WITH_MINIO_AK
MINIO_SECRET_KEY=REPLACE_WITH_MINIO_SK
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# --- JWT ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=2592000

# --- Mail (QQ 邮箱 SMTP) ---
MAIL_PROVIDER=qq
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_email@qq.com
MAIL_PWD=REPLACE_WITH_QQ_AUTH_CODE
MAIL_FROM=your_email@qq.com
MAIL_FROM_NAME=千卡日记

# --- AI ---
DEEPSEEK_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_VISION=deepseek-v4-vision

# 阿里云百炼（qwen-vl 备胎 + embedding v3）
DASHSCOPE_KEY=REPLACE_WITH_DASHSCOPE_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_VISION=qwen-vl-plus
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# --- AI 用量默认配额（免费用户每日） ---
AI_QUOTA_PHOTO=5
AI_QUOTA_CHAT=20
AI_QUOTA_DELIVERY=3

# --- 前端 ---
VITE_API_BASE=/api
VITE_APP_NAME=千卡日记
