# =============================================================================
# 千卡日记 · 生产环境模板（docker-compose 生效）
# 复制为 docker/.env.prod（勿提交），逐项替换 REPLACE_WITH_*
# 架构：独立 pg + redis + api + web + nginx · MinIO 复用宿主
# 出网：走 frpc → frps → 用户自己的域名反代
# =============================================================================

# --- App 基础 ---
APP_ENV=production
IMAGE_TAG=0.1.0
NGINX_PORT=17180

# --- Database (compose 内独立 pg 容器) ---
DB_NAME=qianka
DB_USER=qk
DB_PWD=REPLACE_WITH_STRONG_PWD

# --- Redis (compose 内独立 redis 容器) ---
# compose 内网自动 redis://redis:6379/0 · 无需手填

# --- MinIO (复用宿主 · 侦查过端口 19000) ---
MINIO_ENDPOINT=host.docker.internal
MINIO_PORT=19000
MINIO_ACCESS_KEY=REPLACE_WITH_MINIO_AK
MINIO_SECRET_KEY=REPLACE_WITH_MINIO_SK
MINIO_USE_SSL=false
MINIO_REGION=us-east-1
MINIO_BUCKET=qianka

# --- JWT (openssl rand -hex 64 生成) ---
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_ACCESS_TTL=1800
JWT_REFRESH_TTL=2592000

# --- Mail (QQ 邮箱 SMTP) ---
MAIL_PROVIDER=qq
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=REPLACE_WITH_EMAIL@qq.com
MAIL_PASS=REPLACE_WITH_QQ_AUTH_CODE
MAIL_FROM=REPLACE_WITH_EMAIL@qq.com
MAIL_FROM_NAME=千卡日记

# --- AI · DeepSeek ---
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_CHAT=deepseek-chat
DEEPSEEK_MODEL_VISION=deepseek-v4-vision

# --- AI · 阿里云百炼 (qwen-vl 备胎 + embedding v3) ---
DASHSCOPE_API_KEY=REPLACE_WITH_DASHSCOPE_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_VISION=qwen-vl-plus
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# --- AI 免费用户每日配额 ---
AI_QUOTA_PHOTO=5
AI_QUOTA_CHAT=20
AI_QUOTA_DELIVERY=3

# --- App Origin (前端 CORS · 用户填自己的域名) ---
APP_ORIGIN=https://your-domain.example.com
